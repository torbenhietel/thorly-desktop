{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "doneby",
  "version": "0.1.0",
  "identifier": "io.doneby.desktop",
  "build": {
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "doneby",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "AI-Mitarbeiter-Plattform für den DACH-Mittelstand",
    "longDescription": "doneby.io ist die offene Plattform für AI-Mitarbeiter mit deutscher Datenhoheit. Anna für Akquise, Bernd für Backoffice, Lisa für Marketing — oder dein eigener Mitarbeiter.",
    "publisher": "TH Consulting GmbH",
    "homepage": "https://doneby.io",
    "windows": {
      "wix": {
        "language": ["de-DE", "en-US"]
      },
      "nsis": {
        "displayLanguageSelector": true,
        "installerIcon": "icons/icon.ico",
        "installMode": "currentUser"
      }
    },
    "macOS": {
      "minimumSystemVersion": "10.15"
    }
  },
  "plugins": {
    "updater": {
      "active": true,
      "endpoints": [
        "https://github.com/torbenhietel/doneby-desktop/releases/latest/download/latest.json"
      ],
      "dialog": true,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDQyODJEMjVEMTU3NTk2OTIKUldTU2xuVVZYZEtDUW1jMVRVWHd2NjhIbTJhUDUxd0FheGJ6N2dXbFZRV094ZGZodG5URVhBUmkK"
    }
  }
}
